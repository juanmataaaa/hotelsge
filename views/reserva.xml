<odoo>
  
    <!-- Vista List -->
    <record id="view_reserva_tree" model="ir.ui.view">
        <field name="name">hotelsge.reserva.tree</field>
        <field name="model">hotelsge.reserva</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="cliente_id"/>
                <field name="fecha_entrada"/>
                <field name="fecha_salida"/>
                <field name="noches"/>
                <field name="total"/>
            </list>
        </field>
    </record>
<!-- Vista Calendar -->
<record id="view_reserva_calendar" model="ir.ui.view">
    <field name="name">hotelsge.reserva.calendar</field>
    <field name="model">hotelsge.reserva</field>
    <field name="arch" type="xml">
        <calendar string="Calendario de Reservas"
                  date_start="fecha_entrada"
                  date_stop="fecha_salida"
                  color="cliente_id">
            <field name="cliente_id"/>
            <field name="habitaciones_ids"/>
        </calendar>
    </field>
</record>

    <!-- Vista Form -->
    <record id="view_reserva_form" model="ir.ui.view">
        <field name="name">hotelsge.reserva.form</field>
        <field name="model">hotelsge.reserva</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="cliente_id"/>
                        <field name="fecha_entrada"/>
                        <field name="fecha_salida"/>
                        <field name="vehiculos"/>
                        <field name="habitaciones_ids" widget="many2many_tags" domain="[('estado', '=', 'libre')]"/>
                        <field name="noches" readonly="1"/>
                        <field name="total" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    
</odoo>
